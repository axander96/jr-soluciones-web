{
  "hosting": {
    "target": "web",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".git/**",
      ".firebase/**",
      ".vscode/**",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  }
}
